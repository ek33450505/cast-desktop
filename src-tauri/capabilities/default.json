{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the main window — events, window controls, shell sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:scope-home-recursive",
    {
      "identifier": "fs:scope",
      "deny": [
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.netrc" },
        { "path": "$HOME/.config/gh/**" },
        { "path": "$HOME/Library/Keychains/**" },
        { "path": "$HOME/Library/Application Support/Google/Chrome/**" },
        { "path": "$HOME/Library/Application Support/Firefox/**" }
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [{ "url": "https://github.com/**" }]
    }
  ]
}
