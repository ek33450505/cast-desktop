{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the main window — events, window controls, shell sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/.claude/**" },
        { "path": "$HOME/Projects/**" }
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [{ "url": "https://github.com/**" }]
    }
  ]
}
