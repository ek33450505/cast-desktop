{
  "productName": "Cast",
  "version": "0.1.0",
  "identifier": "com.cast-desktop.app",
  "build": {
    "beforeBuildCommand": "npm run build && npm run build:sidecar",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3001",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cast",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "url": "http://localhost:3001/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": ["binaries/cast-server"]
  }
}
