{
  "productName": "Cast Desktop",
  "version": "0.1.0",
  "identifier": "com.cast-desktop.app",
  "build": {
    "beforeBuildCommand": "npm run build && npm run build:sidecars",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cast Desktop",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "url": "http://localhost:5173/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": ["binaries/cast-server", "binaries/cast-lsp-ts"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Your agents, in the room.",
    "longDescription": "Cast Desktop is a local-first developer workspace built for AI-native workflows — terminal, editor, and agent observability on one surface."
  }
}
