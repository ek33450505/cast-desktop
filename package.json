{
  "name": "cast-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"vite\"",
    "server:dev": "cd server && tsx watch index.ts",
    "build": "tsc -b && vite build",
    "build:server": "cd server && npm install && npm run build",
    "build:sidecar": "mkdir -p src-tauri/binaries && cd server && bun build --compile --minify --target=bun index.ts --outfile ../src-tauri/binaries/cast-server-aarch64-apple-darwin",
    "build:app": "npm run build && npm run build:server && npm run build:sidecar && cargo tauri build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@formkit/auto-animate": "^0.9.0",
    "@tanstack/react-query": "^5.56.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.462.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hotkeys-hook": "^5.2.4",
    "react-markdown": "^9.0.0",
    "react-resizable-panels": "^4.7.5",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "jsdom": "^25.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "shadcn": "^4.1.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
